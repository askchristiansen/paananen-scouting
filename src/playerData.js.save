// ─── POSITION → BENCHMARK KEY ────────────────────────────────────────────────
export function getBenchmarkKey(posGroup) {
  return posGroup ?? null;
}

// ─── POSITION GROUP (canonical) ──────────────────────────────────────────────
// Each player has a posGroup field set explicitly — no regex guessing
